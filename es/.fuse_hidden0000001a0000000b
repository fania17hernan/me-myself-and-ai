<script>
(function(){
  function isDone(m){try{return localStorage.getItem('mmai-done-'+m)==='1'}catch(e){return false}}

  /* ----- racha (honesta, por día) ----- */
  (function(){
    var today=new Date(); today.setHours(0,0,0,0);
    var n=0,last=null;
    try{n=parseInt(localStorage.getItem('mmai-streak')||'0',10)||0;last=localStorage.getItem('mmai-last');}catch(e){}
    if(last){
      var d=new Date(last); d.setHours(0,0,0,0);
      var days=Math.round((today-d)/86400000);
      if(days===0){}
      else if(days===1){n=n+1;}
      else{n=1;}
    } else { n=1; }
    try{localStorage.setItem('mmai-streak',String(n));localStorage.setItem('mmai-last',today.toISOString());}catch(e){}
    document.getElementById('streakNum').textContent=n;
  })();

  /* ----- progreso por nivel + total ----- */
  var nodes=[].slice.call(document.querySelectorAll('.node'));
  var totalDone=0,totalAll=0,currentSet=false,afterCount=0;

  nodes.forEach(function(node,idx){
    var mods=node.getAttribute('data-mods').split(',').filter(Boolean);
    var d=0; mods.forEach(function(m){if(isDone(m))d++;});
    totalDone+=d; totalAll+=mods.length;
    var pct=mods.length?Math.round(d/mods.length*100):0;
    node.querySelector('.pbar i').style.width=pct+'%';
    node.querySelector('.pcount').textContent=d+' de '+mods.length+' lecciones';
    var pill=node.querySelector('.pill');
    var complete=(d===mods.length);

    if(complete){
      node.classList.add('done');
      pill.className='pill done'; pill.textContent='Hecho ✓';
    } else if(!currentSet){
      currentSet=true;
      node.classList.add('here');
      pill.className='pill here'; pill.textContent='Estás aquí';
    } else {
      afterCount++;
      if(afterCount===1){ pill.className='pill next'; pill.textContent='Sigue'; }
      else { pill.style.display='none'; }
    }
  });

  /* ----- medidor del encabezado ----- */
  var op=totalAll?Math.round(totalDone/totalAll*100):0;
  document.getElementById('fill').style.width=op+'%';
  document.getElementById('progText').textContent=totalDone+' / '+totalAll+' lecciones';
  document.getElementById('jmeta').textContent=op+'% completado';

  /* ----- saludo y botón dinámicos ----- */
  var here=document.querySelector('.node.here');
  var allDone=(totalDone===totalAll && totalAll>0);
  if(allDone){
    document.getElementById('greeting').textContent='¡Lo lograste! Vuelve cuando quieras.';
    document.getElementById('ctaLabel').textContent='Repasar el glosario';
    document.getElementById('ctaBtn').setAttribute('href','glossary.html');
    document.getElementById('ctaSub').innerHTML='Los 4 niveles completos · ya tienes las bases';
  } else if(totalDone===0){
    document.getElementById('ctaLabel').textContent='Empieza la lección 1';
    document.getElementById('ctaBtn').setAttribute('href','level-1.html');
  } else if(here){
    var name=here.querySelector('.lname').textContent;
    document.getElementById('greeting').textContent='Qué bueno verte. Sigamos.';
    document.getElementById('ctaLabel').textContent='Continuar: '+name;
    document.getElementById('ctaBtn').setAttribute('href',here.getAttribute('data-href'));
  }

  /* ----- logros ----- */
  nodes.forEach(function(node,idx){
    if(node.classList.contains('done')){
      var b=document.querySelector('.badge[data-lvl="'+idx+'"]');
      if(b)b.classList.add('lit');
    }
  });
})();
</script>
